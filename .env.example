# ============================================================
# YupSoul Video Factory — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# --- Security ---
# Generate: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
RENDER_WEBHOOK_SECRET=your_webhook_secret_here

# --- Brand ---
BRAND_NAME=YupSoul
BRAND_BOT_URL=https://t.me/Yup_Soul_bot
BRAND_SITE_URL=https://www.yupsoul.online
BRAND_LANGUAGE=ru

# --- LLM (choose one, Gemini recommended — free) ---
# Option 1: Google Gemini FREE (1000 req/day)
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Option 2: DeepSeek FREE (500M tokens/month)
# Get at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Option 3: Anthropic Claude (paid)
ANTHROPIC_API_KEY=

# --- TTS Voice (choose one) ---
# Option 1: Fish Audio FREE (200 min/month)
# Get at: https://fish.audio/
# Find voice ID in Fish Audio voice library (Russian voices)
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=ad9d7ac98da2471fae4a5a44a86cfb08

# Option 2: ElevenLabs FREE (10,000 chars/month)
# Get at: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Cloudflare R2 Storage (FREE: 10GB, $0 egress) ---
# Create bucket at: https://dash.cloudflare.com/ → R2
# Create API token with R2 read/write permissions
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=yupsoul-videos
# Set this if you have a custom domain on R2 bucket (optional)
# Without it, presigned URLs are used (valid 7 days)
R2_PUBLIC_URL=https://videos.yourdomain.com

# --- GitHub Actions (FREE: 2000 min/month private, unlimited public) ---
# Create PAT at: https://github.com/settings/tokens
# Permissions needed: repo, workflow
GITHUB_OWNER=your_github_username
GITHUB_REPO=video_factory
GITHUB_PAT=ghp_your_personal_access_token
GITHUB_WORKFLOW=render-video.yml

# --- Telegram Bot (FREE, delivery of download links) ---
# Create bot via @BotFather → get token
# Add bot to channel as admin → get channel ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- App URL (set this after first Vercel deploy) ---
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
